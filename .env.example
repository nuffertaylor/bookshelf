# Database - local: use Docker PostgreSQL, AWS: use CockroachDB
DATABASE_URL=postgresql://user:password@host:port/database

# AWS - local: use LocalStack, AWS: leave empty for production
AWS_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# SSL Certificate - local: use generated cert, AWS: use production cert
SSL_CERT_PATH=./root.crt
